{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\n# ------------------------------------------\n# \n# \tProject:\n#\tAuthor:\n#\tCreated:\n#\tConfiguration:\n# \n# ------------------------------------------\n\n# Library imports\nfrom vex import *\nfrom math import pi\n\n# Begin project code\n\n# left motors\nm1 = Motor(Ports.PORT1, GearSetting.RATIO_18_1, True)\nm2 = Motor(Ports.PORT3, GearSetting.RATIO_18_1, True)\nlm = MotorGroup(m1, m2)\n# right motors\nm3 = Motor(Ports.PORT2, GearSetting.RATIO_18_1, False)\nm4 = Motor(Ports.PORT4, GearSetting.RATIO_18_1, False)\nrm = MotorGroup(m3, m4)\n\n# sensors\nclass MyInertial(Inertial):\n    def rotation(self, units):\n        return super().rotation(units) * 361 / 360\n    \ng = MyInertial(Ports.PORT5)\nINCH_TO_MM = 25.4\n\nwheelTravel = 4 * pi * INCH_TO_MM # mm\ntrackWidth = 242 # mm\nwheelBase = 10 * INCH_TO_MM # mm\nunits = MM\nexternalGearRatio = 60/60 # 60T on motor, 60T on wheel\n\nclass MyDriveTrain:\n    def __init__(self, lm, rm, wheelTravel, trackWidth, wheelBase, units, externalGearRatio):\n        self.lm = lm\n        self.rm = rm\n        self.wheelTravel = wheelTravel\n        self.trackWidth = trackWidth\n        self.wheelBase = wheelBase\n        self.externalGearRatio = externalGearRatio\n\n    def drive_for(self, direction, distance, units, wait):\n        self.lm.spin_for(direction, distance / self.wheelTravel, TURNS, wait=False)\n        self.rm.spin_for(direction, distance / self.wheelTravel, TURNS, wait=True)\n\n\n    def turn_for(self, direction, angle, units, wait):\n        wheel_turns = (pi * self.trackWidth / wheelTravel) * (angle / 360)\n        self.lm.spin_for(FORWARD, wheel_turns, TURNS, wait=False)\n        self.rm.spin_for(REVERSE, wheel_turns, TURNS, wait=True)\n\ndt = SmartDrive(lm, rm, g, wheelTravel, trackWidth, wheelBase, units, externalGearRatio)\n\ndef pre_autonomous():\n    # actions to do when the program starts\n    brain.screen.clear_screen()\n    brain.screen.print(\"pre auton code\")\n    wait(100, MSEC)\n\n    g.calibrate()\n    \n    wait(2,SECONDS)\n\ndef gain_example_code():\n    proportinoal_gain = 0.5\n    target_heading = 90\n    current_heading = g.rotation(DEGREES)\n    heading_error = target_heading - current_heading\n    error_threshold = 0.5 # degrees error we are OK with\n    while abs(heading_error) > error_threshold:\n        speed = proportinoal_gain * heading_error\n        lm.spin(FORWARD, speed, PERCENT)\n        rm.spin(REVERSE, speed, PERCENT)\n        wait(10, MSEC)\n        current_heading = g.rotation(DEGREES)\n        heading_error = target_heading - current_heading\n    dt.stop(BRAKE)\n\ndef autonomous():\n    brain.screen.clear_screen()\n    brain.screen.print(\"autonomous code\")\n    # place automonous code here\n    # leg1\n\n    dt.set_drive_velocity(67, PERCENT)\n    dt.set_turn_velocity(67, PERCENT)\n    dt.set_turn_constant(0.7)\n    dt.set_turn_threshold(1.0)\n    # dt.set_timeout(0.1, SECONDS)\n\n    # Test turn 10 times\n    if False:\n        dt.turn_for(RIGHT, 10 * 360, DEGREES)\n        return\n    # Test our own turn code\n    if False:\n        gain_example_code()\n        return\n\n    dt.drive_for(FORWARD, 1200, MM, wait=True)\n    dt.turn_for(RIGHT, 90, DEGREES, wait=True)\n    # leg2\n    dt.drive_for(FORWARD, 1200, MM, wait=True)\n    dt.turn_for(RIGHT, 90, DEGREES, wait=True)\n    # leg3\n    dt.drive_for(FORWARD, 1200, MM, wait=True)\n    dt.turn_for(RIGHT, 90, DEGREES, wait=True)\n    # leg4\n    dt.drive_for(FORWARD, 1200, MM, wait=True)\n    dt.turn_for(RIGHT, 90, DEGREES, wait=True)\n\n\ndef user_control():\n    brain.screen.clear_screen()\n    # place driver control in this while loop\n    while True:\n        wait(20, MSEC)\n\n# create competition instance\ncomp = Competition(user_control, autonomous)\npre_autonomous()\n","textLanguage":"python","robotConfig":[],"slot":7,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}